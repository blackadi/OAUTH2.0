# API base URL — required. Points to the deployed Authlete Node server.
VITE_API_BASE_URL=http://localhost:3000

# Optional defaults that pre-fill the dashboard forms.
# All credentials can also be entered directly in the UI.
VITE_CLIENT_ID=your_client_id
VITE_REDIRECT_URI=http://localhost:3001/callback
VITE_SCOPES=openid profile email

# Production overrides (set these in your hosting dashboard, not locally)
VITE_PROD_API_BASE_URL=
VITE_PROD_REDIRECT_URI=

# Development settings
VITE_DEV_CLIENT_PORT=3001
VITE_DEV_CLIENT_HOST=localhost
