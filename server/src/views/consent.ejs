<%- include('partials/head', { title: 'Consent' }) %>
<body>
  <main>
  <div class="card">
    <div class="consent-header">
      <div class="consent-client-icon"><%= (clientName || '?').charAt(0).toUpperCase() %></div>
      <div class="consent-client-info">
        <h2><%= clientName || 'Unknown Client' %></h2>
        <p>wants to access your account</p>
      </div>
    </div>
    <p class="lead">This application is requesting the following permissions:</p>
    <form method="POST" action="/api/session/consent">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <ul class="scope-list">
        <%- include('partials/scope-list', { scopes: scopes || ['openid', 'profile'] }) %>
      </ul>
      <% if (authorizationDetails && authorizationDetails.length > 0) { %>
        <div class="rar-section">
          <p class="rar-heading">Rich Authorization Details</p>
          <% authorizationDetails.forEach(function(detail) { %>
            <div class="rar-card">
              <div class="rar-card-header">
                <span class="rar-type-badge"><%= detail.type %></span>
              </div>
              <div class="rar-card-body">
                <% if (detail.locations && detail.locations.length > 0) { %>
                  <div class="rar-field">
                    <span class="rar-field-label">Locations</span>
                    <ul class="rar-field-list">
                      <% detail.locations.forEach(function(loc) { %>
                        <li><code><%= loc %></code></li>
                      <% }) %>
                    </ul>
                  </div>
                <% } %>
                <% if (detail.actions && detail.actions.length > 0) { %>
                  <div class="rar-field">
                    <span class="rar-field-label">Actions</span>
                    <div class="rar-tags">
                      <% detail.actions.forEach(function(action) { %>
                        <span class="rar-tag"><%= action %></span>
                      <% }) %>
                    </div>
                  </div>
                <% } %>
                <% if (detail.datatypes && detail.datatypes.length > 0) { %>
                  <div class="rar-field">
                    <span class="rar-field-label">Data Types</span>
                    <div class="rar-tags">
                      <% detail.datatypes.forEach(function(dt) { %>
                        <span class="rar-tag"><%= dt %></span>
                      <% }) %>
                    </div>
                  </div>
                <% } %>
                <% if (detail.identifier) { %>
                  <div class="rar-field">
                    <span class="rar-field-label">Identifier</span>
                    <code><%= detail.identifier %></code>
                  </div>
                <% } %>
                <% if (detail.privileges && detail.privileges.length > 0) { %>
                  <div class="rar-field">
                    <span class="rar-field-label">Privileges</span>
                    <div class="rar-tags">
                      <% detail.privileges.forEach(function(priv) { %>
                        <span class="rar-tag"><%= priv %></span>
                      <% }) %>
                    </div>
                  </div>
                <% } %>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
      <% if (redirectUri) { %>
        <div class="consent-redirect">
          <span class="consent-redirect-label">Redirect URI</span>
          <code class="consent-redirect-value"><%= redirectUri %></code>
        </div>
      <% } %>
      <label class="consent-remember">
        <input type="checkbox" name="remember" value="true" checked />
        <span>Remember my decision for future requests from this client</span>
      </label>
      <div class="buttons">
        <button type="submit" name="decision" value="approve" class="approve">Approve</button>
        <button type="submit" name="decision" value="deny" class="deny">Deny</button>
      </div>
    </form>
  </div>
  </main>
  <%- include('partials/footer') %>
</body>
</html>
