<% var __scopeDescs = {
  openid: 'Access your identity information (subject identifier)',
  profile: 'View your profile information (name, picture, etc.)',
  email: 'View your email address',
  address: 'View your physical address',
  phone: 'View your phone number',
  offline_access: 'Access your data when you are not actively using the application'
}; %>
<% (scopes || []).forEach(function(s) { %>
  <% var name = typeof s === 'object' ? (s.name || '') : String(s); %>
  <% var label = name.charAt(0).toUpperCase() + name.slice(1).replace(/_/g, ' '); %>
  <li class="scope-item">
    <div>
      <div class="scope-name"><%= label %></div>
      <div class="scope-desc"><%= __scopeDescs[name] || 'Access to ' + name.replace(/_/g, ' ') + ' data' %></div>
    </div>
  </li>
<% }) %>
