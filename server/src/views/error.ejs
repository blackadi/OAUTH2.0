<%- include('partials/head', { title: title || 'Error' }) %>
<body>
  <main>
  <div class="card error-card" role="alert">
    <% var isClient = typeof status !== 'undefined' && status < 500; %>
    <div class="error-status <%= isClient ? 'error-status-4xx' : 'error-status-5xx' %>"><%= typeof status !== 'undefined' ? status : '?' %></div>
    <h1><%= title || 'Error' %></h1>
    <p class="lead"><%= message || 'An unexpected error occurred. Please try again.' %></p>
    <% if (typeof path !== 'undefined' && path) { %>
      <p class="error-path"><%= path %></p>
    <% } %>

    <% if (details) { %>
      <details class="error-details">
        <summary>Stack Trace</summary>
        <pre><%= details %></pre>
      </details>
    <% } %>

    <div class="error-actions">
      <a href="/" class="primary">Go Home</a>
      <button onclick="window.history.back()" class="secondary">Go Back</button>
    </div>

    <div class="foot">If the problem persists, please open a GitHub issue.</div>
  </div>
  </main>
  <%- include('partials/footer') %>
</body>
</html>
