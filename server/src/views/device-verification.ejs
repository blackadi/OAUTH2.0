<%- include('partials/head', { title: 'Device Verification' }) %>
<body>
  <main>
  <div class="card device-card">

    <% if (done) { %>
      <h1>Verification <%- success ? 'Successful' : 'Failed' %></h1>
      <p class="lead"><%= success || error %></p>
      <div class="foot device-actions">
        <a href="/" class="primary">Go Home</a>
      </div>

    <% } else if (!clientName) { %>

      <h1>Device Verification</h1>
      <% if (error) { %>
        <div class="error-message" role="alert"><span class="error-icon" aria-hidden="true">!</span><%= error %></div>
      <% } %>
      <p class="lead">Enter the code displayed on your device to sign in.</p>
      <form method="post" action="/device">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <label for="user_code">User Code</label>
        <input type="text" id="user_code" name="user_code"
               value="<%= userCode || '' %>"
               placeholder="e.g. ABCD-1234" required autofocus
               class="user-code-input" />
        <div class="actions device-actions">
          <button type="submit" class="primary">Verify</button>
        </div>
      </form>

    <% } else { %>

      <div class="consent-header">
        <div class="consent-client-icon"><%= (clientName || '?').charAt(0).toUpperCase() %></div>
        <div class="consent-client-info">
          <h2><%= clientName %></h2>
          <p>requesting access to your account</p>
        </div>
      </div>

      <% if (scopes && scopes.length > 0) { %>
        <p class="lead device-lead">This device would like to:</p>
        <ul class="scope-list">
          <%- include('partials/scope-list', { scopes: scopes }) %>
        </ul>
      <% } %>

      <form method="post" action="/device/consent">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <input type="hidden" name="user_code" value="<%= userCode %>" />
        <label for="username">Username</label>
        <input type="text" id="username" name="username" required autocomplete="username" />
        <label for="auth-password">Password</label>
        <input type="password" id="auth-password" name="password" required autocomplete="current-password" />
        <div class="buttons device-actions">
          <button type="submit" name="result" value="AUTHORIZED" class="approve">Authorize</button>
          <button type="submit" name="result" value="ACCESS_DENIED" class="deny">Deny</button>
        </div>
      </form>

    <% } %>
  </div>
  </main>
  <%- include('partials/footer') %>
</body>
</html>
