<%- include('partials/head', { title: 'Available Routes' }) %>
<body>
  <div class="wrap">
    <header>
      <div>
        <h1><a href="/api/routes" class="link" target="_blank">Available Routes</a></h1>
        <p class="base">Base URL: <code id="base">loading...</code></p>
      </div>
    </header>
    <%- include('partials/routes-table') %>
    <footer>Click GET links to open in your browser. Use the copy button to copy curl commands for POST/PATCH/DELETE endpoints.</footer>
  </div>
  <script>
    (async function() {
      try {
        const res = await fetch('/api/routes.json');
        const data = await res.json();
        document.getElementById('base').textContent = data.base || (location.protocol + '//' + location.host);
      } catch(e) { console.error(e); }
    })();
  </script>
</body>
</html>
