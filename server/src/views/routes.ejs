<%- include('partials/head', { title: 'Available Routes' }) %>
<body>
  <main>
  <div class="wrap">
    <header>
      <h1><a href="/api/routes" class="link" target="_blank">Available Routes</a></h1>
      <p class="base">Base URL: <code id="base">loading...</code></p>
      <p class="base route-meta">Click GET links to open. Use the copy button for curl commands.</p>
    </header>
    <div class="routes-toolbar">
      <input type="search" id="route-filter" class="route-filter-input" placeholder="Filter by path, method, or description…" aria-label="Filter routes" />
      <span class="route-count" id="route-count"></span>
    </div>
    <%- include('partials/routes-table') %>
    <%- include('partials/footer') %>
  </div>
  </main>
  <script>
    (async function() {
      try {
        const res = await fetch('/api/routes.json');
        const data = await res.json();
        document.getElementById('base').textContent = data.base || (location.protocol + '//' + location.host);
      } catch(e) { console.error(e); }
    })();

    (function() {
      var filter = document.getElementById('route-filter');
      var count = document.getElementById('route-count');
      if (!filter) return;
      filter.addEventListener('input', function() {
        var q = this.value.toLowerCase();
        var rows = document.querySelectorAll('#routes-body tr');
        var vis = 0;
        rows.forEach(function(tr) {
          if (tr.classList.contains('route-group-header')) {
            tr.style.display = q ? 'none' : '';
            return;
          }
          var match = tr.textContent.toLowerCase().indexOf(q) !== -1;
          tr.style.display = match ? '' : 'none';
          if (match) vis++;
        });
        if (count) count.textContent = q ? vis + ' matched' : '';
      });
    })();
  </script>
</body>
</html>
