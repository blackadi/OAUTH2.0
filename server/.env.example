# Authlete Configuration
AUTHLETE_BEARER_TOKEN=your_authlete_bearer_token_here
AUTHLETE_BASE_URL=https://eu.authlete.com
AUTHLETE_SERVICE_ID=your_authlete_service_id_here

# Server Configuration
PORT=3000
NODE_ENV=development
MORGAN_FORMAT=combined
LOG_LEVEL=info

# Session Configuration
SESSION_SECRET=change_this_to_a_random_secret_in_production

# Redis — unset to use in-memory store (session data lost on restart)
# For local Docker Redis: redis://localhost:6379
# REDIS_URL=redis://localhost:6379

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Logout — post-logout redirect URI and client ID for the logout view
LOGOUT_REDIRECT_URI=http://localhost:3000
LOGOUT_CLIENT_ID=your_client_id_here

# Demo users — semicolon-separated: subject:username:password:display_name
# AUTH_USERS=admin:admin:password:Admin User;sub2:user2:pass2:Name2

# JWT keys — for locally-signed JWTs (createLocalToken endpoint, dev only)
# JWT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\nMFkw......\n-----END PUBLIC KEY-----\n"
# JWT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\nMEE......\n-----END PRIVATE KEY-----\n"
# JWT_ISSUER=https://example.test/

# JWKS URI — used to validate incoming backchannel logout tokens from other OPs
# JWKS_URI=https://other-op.example.com/.well-known/jwks.json

# Token Management API — if set, all /api/token management routes
# (create, list, update, delete, revoke, reissue) require Basic auth
# with these credentials. If unset, management routes are unprotected.
MGMT_CLIENT_ID=
MGMT_CLIENT_SECRET=
